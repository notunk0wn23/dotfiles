build: http.o main.o
	g++ build/obj/http.o build/obj/main.o -o build

main: source/main.cpp source/http.h
	if [ ! -d build ]; then mkdir build; fi
	if [ ! -d build/obj ]; then mkdir build/obj; fi
	g++ source/main.cpp -o build/main
	printf "\n \n"
	./build/main

http.o: source/http.cpp source/http.h
	g++ -c source/http.cpp -o build/obj/http.o
	s
clean: 
	rm -rf build
